rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // イベント
    match /events/{eventId} {
      // 誰でも読み取り可能
      allow read: if true;
      
      // 作成: reCAPTCHAトークンが必要（クライアントサイドで検証）
      // 本番環境ではCloud Functionsでサーバーサイド検証を推奨
      allow create: if request.resource.data.title != null 
                    && request.resource.data.candidates != null
                    && request.resource.data.recaptchaToken != null;
      
      // 更新: fixedCandidateIdのみ許可
      allow update: if request.resource.data.diff(resource.data).affectedKeys()
                    .hasOnly(['fixedCandidateId', 'updatedAt']);
      
      // 削除: 期限切れのイベントのみ（Cloud Functionsで実行推奨）
      allow delete: if resource.data.expiresAt <= request.time;
      
      // 回答
      match /responses/{responseId} {
        allow read: if true;
        allow create: if request.resource.data.name != null 
                      && request.resource.data.answers != null;
        allow update, delete: if false;
      }
      
      // チャット
      match /chat/{messageId} {
        allow read: if true;
        allow create: if request.resource.data.user != null 
                      && request.resource.data.message != null;
        allow update, delete: if false;
      }
      
      // DM
      match /dms/{dmId} {
        allow read: if true; // 本番では主催者認証が必要
        allow create: if request.resource.data.to != null 
                      && request.resource.data.message != null;
        allow update, delete: if false;
      }
    }
  }
}
